# Telegram bot token from @BotFather
TG_BOT_TOKEN=123456:ABC...

# Your Telegram numeric user id (the owner: full access, session management)
OWNER_USER_ID=123456789

# Optional: comma/space separated user ids allowed to chat with the restricted guest profile
GUEST_USER_IDS=

# Optional: a group chat id the bot serves (guest profile; forum topics = separate sessions)
TARGET_GROUP_ID=0

# Optional: session id to bind the owner's DM to on first contact
RESUME_SESSION_ID=

# Optional: default working directory for the owner's sessions (default: $HOME)
OWNER_DEFAULT_CWD=

# Optional: colon-separated dirs the guest profile may read / write
GUEST_READ_DIRS=
GUEST_WRITE_DIRS=
# Optional: file with a custom system prompt for the guest profile
GUEST_SYSTEM_PROMPT_FILE=

# Optional: faster-whisper model for voice messages (default: large-v3-turbo)
WHISPER_MODEL=large-v3-turbo
# Optional: days to keep received files under <cwd>/.tgbot/media (default: 14)
TGBOT_MEDIA_TTL_DAYS=14
