[Unit]
Description=Telegram bridge for Claude Code (claude-agent-sdk)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/tg-claude-bot
Environment=PATH=/home/YOUR_USER/.local/bin:/usr/local/bin:/usr/bin:/bin
# Secrets do NOT belong here: unit files are world-readable. Put them in the
# project's .env (chmod 600) — the bot loads it and children inherit. If the
# CLI isn't logged in for this user, add CLAUDE_CODE_OAUTH_TOKEN there too
# (from `claude setup-token`).
ExecStart=/home/YOUR_USER/.local/bin/uv run python bot.py
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
